# NIP-85 Service Provider Configuration

# Hex private key for signing assertions (leave empty to auto-generate)
NIP85_MASTER_KEY=caabaa4014206a347350469872a71ef72812b6def6462be3431e155ce2cdf29f

# Relay port
PORT=3334

# Storage relays (comma-separated)
STORAGE_RELAYS=wss://nostr-01.uid.ovh,wss://nostr-02.uid.ovh

# Local database path
DB_PATH=./data/cipolin.db

# Fetch TTL - skip re-fetching if within this duration (seconds)
FETCH_TTL_SECONDS=60

# Fetch timeout - timeout per relay connection (seconds)
FETCH_TIMEOUT_SECONDS=30

# Neo4j settings for user rank PageRank
NEO4J_URI=neo4j://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# Rank cache TTL and query timeout (seconds)
RANK_CACHE_TTL_SECONDS=15
NEO4J_QUERY_TIMEOUT_SECONDS=20

# GrapeRank: replace global PageRank with personalized PageRank.
# Requires NIP-42 AUTH (ENABLE_NIP42_AUTH=true or the client must authenticate).
# Falls back to global PageRank when disabled or the client is not authenticated.
GRAPERANK_ENABLED=false

# Signal weights used when building the trust graph.
# NIP-51 mute lists (kind 10000) and NIP-56 reports (kind 1984) are always
# recorded in Neo4j regardless of GRAPERANK_ENABLED.
# When GrapeRank is active these weights are applied as post-processing score
# multipliers: 1.0 = no change, 0.0 = fully suppress, 0.5 = halve the score.
SIGNAL_WEIGHT_FOLLOW=1.0
SIGNAL_WEIGHT_MUTE=0.0
SIGNAL_WEIGHT_REPORT=0.0

# Require NIP-42 AUTH for requests (true/false)
ENABLE_NIP42_AUTH=false

# Optional request policy plugin command.
# Example: ./scripts/request-policy.js
REQUEST_POLICY_PLUGIN=

# Plugin response timeout in milliseconds
REQUEST_POLICY_TIMEOUT_MS=1500

# If true, allow requests when the plugin fails/times out. If false, fail closed.
REQUEST_POLICY_FAIL_OPEN=false
