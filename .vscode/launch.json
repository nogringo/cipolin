{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug cipolin",
			"type": "go",
			"request": "launch",
			"mode": "debug",
			"program": "${workspaceFolder}/cmd/cipolin/main.go",
			"cwd": "${workspaceFolder}",
			"envFile": "${workspaceFolder}/.env"
		},
		{
			"name": "Debug current package",
			"type": "go",
			"request": "launch",
			"mode": "auto",
			"program": "${fileDirname}",
			"cwd": "${workspaceFolder}",
			"envFile": "${workspaceFolder}/.env"
		},
		{
			"name": "Attach to running Go process",
			"type": "go",
			"request": "attach",
			"mode": "local",
			"processId": "${command:pickProcess}"
		}
	]
}